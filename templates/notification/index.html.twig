{% extends 'base.html.twig' %}

{% block title %}Notifications - StockManager Pro{% endblock %}
{% block page_title %}Notifications{% endblock %}

{% block body %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-1" style="font-weight:700;">
            <i class="bi bi-bell-fill me-2" style="color:var(--primary);"></i>Notifications
        </h4>
        <p class="text-muted mb-0" style="font-size:0.85rem;">
            {{ unreadCount }} notification{{ unreadCount > 1 ? 's' : '' }} non lue{{ unreadCount > 1 ? 's' : '' }}
        </p>
    </div>
    {% if unreadCount > 0 %}
        <button class="btn btn-outline-primary btn-sm" onclick="markAllNotificationsRead()">
            <i class="bi bi-check2-all me-1"></i> Tout marquer comme lu
        </button>
    {% endif %}
</div>

<div class="table-card">
    {% if notifications|length > 0 %}
        {% for notification in notifications %}
            <div class="d-flex align-items-start gap-3 p-3 {{ not notification.isRead ? 'bg-light' }}" style="border-bottom:1px solid #f3f4f6;transition:all 0.2s;">
                <div style="width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;
                    {% if notification.type == 'category' %}background:var(--primary-light);color:var(--primary);
                    {% elseif notification.type == 'product' %}background:var(--success-light);color:var(--success);
                    {% elseif notification.type == 'fournisseur' %}background:var(--warning-light);color:var(--warning);
                    {% else %}background:var(--info-light);color:var(--info);{% endif %}">
                    <i class="bi {{ notification.icon ?? 'bi-bell-fill' }}"></i>
                </div>
                <div style="flex:1;">
                    <p style="margin:0;font-size:0.9rem;color:var(--text-primary);font-weight:{{ not notification.isRead ? '600' : '400' }};">
                        {{ notification.message }}
                    </p>
                    <div class="d-flex align-items-center gap-2 mt-1">
                        <span style="font-size:0.78rem;color:var(--text-muted);">
                            <i class="bi bi-clock me-1"></i>{{ notification.timeAgo }}
                        </span>
                        <span class="badge-purple" style="font-size:0.7rem;">
                            {% if notification.type == 'category' %}Catégorie
                            {% elseif notification.type == 'product' %}Produit
                            {% elseif notification.type == 'fournisseur' %}Fournisseur
                            {% else %}{{ notification.type }}{% endif %}
                        </span>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-1">
                    {% if not notification.isRead %}
                        <span style="width:10px;height:10px;border-radius:50%;background:var(--primary);display:inline-block;" title="Non lue"></span>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-bell-slash" style="font-size:3rem;color:var(--text-muted);"></i>
            <p class="mt-3" style="color:var(--text-muted);font-size:0.9rem;">Aucune notification pour le moment</p>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block page_scripts %}
<script>
    function markAllNotificationsRead() {
        fetch('{{ path('notification_mark_all_read') }}', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).then(response => response.json()).then(data => {
            if (data.success) {
                location.reload();
            }
        });
    }
</script>
{% endblock %}
